# ─── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/

# ─── Virtual environment ──────────────────────────────────────────────────────
venv/
.venv/

# ─── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
test_*.py

# ─── Type checking ────────────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ─── Generated certificate files ──────────────────────────────────────────────
generated/
assets/*.png
assets/*.jpg

# ─── Alembic ──────────────────────────────────────────────────────────────────
# alembic.ini and migrations/ are tracked; only exclude compiled cache
migrations/__pycache__/
migrations/versions/__pycache__/