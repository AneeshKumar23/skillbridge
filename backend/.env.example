# Supabase Connection URL & Keys
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# PostgreSQL Direct Connection String (from Supabase Database settings)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Gemini & Generative AI API Configuration
MODEL_API_KEY=your_gemini_api_key
MODEL_NAME=gemini-1.5-flash

# YouTube Data API Key for Course Materials
YOUTUBE_API_KEY=your_youtube_api_key

# Blockchain/Smart Contract Configuration (Polygon Amoy Testnet)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_ID=80002
NETWORK=polygon-amoy
POLYGON_EXPLORER=https://amoy.polygonscan.com

# Deployer/Signer Metamask Account Configuration
# WARNING: Keep your private keys secure. Do not commit keys to source control.
CONTRACT_DEPLOYER_PRIVATE_KEY=your_metamask_private_key
CONTRACT_ADDRESS=deployed_registry_contract_address

# Base URL of the Frontend for QR Code Verification URL generation
# (e.g., http://localhost:5173 for local, or http://<your_local_ip>:5173 for local Wi-Fi testing)
FRONTEND_URL=http://localhost:5173
